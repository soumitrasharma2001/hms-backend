spring.application.name=ProfileMS
server.port=8090
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/profiledb}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:root}

eureka.client.register-with-eureka=true
eureka.client.service-url.defaultZone=${EUREKA_SERVER_URL:http://localhost:8761/eureka/}
profilems.url=${PROFILEMS_URL:http://localhost:8090}
app.cors.allowed-origins=${CORS_ALLOWED_ORIGINS:http://localhost:5173}

DOCTOR_NOT_FOUND=Doctor not found
DOCTOR_ALREADY_EXISTS=Doctor already exists
PATIENT_NOT_FOUND=Patient not found
PATIENT_ALREADY_EXISTS=Patient already exists



